% Gemini theme layout
\RequirePackage{exscale}
\RequirePackage{ragged2e}
\RequirePackage{changepage}
\RequirePackage{fontspec} % Required for XeLaTeX

% Fonts
\newfontfamily\Raleway[Ligatures=TeX]{Raleway}
\newfontfamily\Lato[Ligatures=TeX]{Lato}
\usefonttheme{professionalfonts}

\setsansfont{Lato}[
  UprightFont=*-Light,
  BoldFont=*-Regular,
  ItalicFont=*-LightItalic
]

\setbeamerfont{headline title}{family=\Raleway,size=\Huge,series=\bfseries}
\setbeamerfont{block title}{family=\Raleway,size=\large,series=\bfseries}
\setbeamerfont{heading}{family=\Lato,series=\bfseries}

% Logo handling
\newlength{\maxlogowidth}
\setlength{\maxlogowidth}{15ex}

\newcommand{\logoright}[1]{\newcommand{\insertlogoright}{#1}}
\newcommand{\logoleft}[1]{\newcommand{\insertlogoleft}{#1}}

% Headline Template
\setbeamertemplate{headline}
{
  \begin{beamercolorbox}{headline}
    \begin{columns}
      \begin{column}{0.15\paperwidth}
        \vskip5ex \raggedright \insertlogoleft \vskip5ex
      \end{column}
      \begin{column}{0.7\paperwidth}
        \centering
        \usebeamerfont{headline title}\inserttitle\\[0.5ex]
        \usebeamerfont{headline author}\insertauthor\\[1ex]
        \usebeamerfont{headline institute}\insertinstitute
      \end{column}
      \begin{column}{0.15\paperwidth}
        \vskip5ex \raggedleft \insertlogoright \vskip5ex
      \end{column}
    \end{columns}
  \end{beamercolorbox}
}

% Block Template
\setbeamertemplate{block begin}
{
  \begin{beamercolorbox}[colsep*=0ex,dp=2ex,center]{block title}
    \usebeamerfont{block title}\insertblocktitle
    \begin{beamercolorbox}[colsep=0.025ex]{block separator}\end{beamercolorbox}
  \end{beamercolorbox}
  \begin{beamercolorbox}[colsep*=0ex]{block body}
  \justifying \setlength{\parskip}{1ex}
}
\setbeamertemplate{block end}{\end{beamercolorbox}\vspace*{2ex}}