% Gemini theme
% https://github.com/anishathalye/gemini

% ====================
% Definitions
% ====================

\definecolor{lightgray}{RGB}{245, 246, 250}
\definecolor{mauve}{HTML}{662E7D}
\definecolor{lightmauve}{HTML}{E6D9E9}
\definecolor{noir}{RGB}{38, 15, 44}
\definecolor{yellow}{RGB}{255, 249, 230}


% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=noir}

% Headline
\setbeamercolor{headline}{fg=lightgray,bg=mauve}
\setbeamercolor{headline rule}{bg=noir}

% Block
\setbeamercolor{block title}{fg=mauve,bg=white}
\setbeamercolor{block separator}{bg=noir}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block alerted title}{fg=mauve,bg=lightmauve}
\setbeamercolor{block alerted separator}{bg=noir}
\setbeamercolor{block alerted body}{fg=black,bg=lightmauve}

% Example Block
\setbeamercolor{block example title}{fg=mauve,bg=yellow}
\setbeamercolor{block example separator}{bg=noir}
\setbeamercolor{block example body}{fg=black,bg=yellow}

% Heading
\setbeamercolor{heading}{fg=black}

% Itemize
\setbeamercolor{item}{fg=noir}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
\setbeamertemplate{bibliography entry article}{}
\setbeamertemplate{bibliography entry title}{}
\setbeamertemplate{bibliography entry location}{}
\setbeamertemplate{bibliography entry note}{}
